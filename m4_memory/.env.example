# Sazabi M4 - Agentic Memory
# Copy to .env and edit

# Path to memory SQLite DB (SEPARATE from M2 sazabi.db)
MEMORY_DB_PATH=/data/memory.db

# API server port (default 8766, different from M2 port 8765)
MEMORY_PORT=8766

# Optional: path to M3 compression directory for LLM summaries
# M3_COMPRESSION_DIR=../m3_compression
