# Sazabi M2 - Environment Variables
# Copy to .env and edit

# SQLite database path (inside container volume)
DB_PATH=/data/sazabi.db

# Service bind address and port
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8765

# Uvicorn log level: debug | info | warning | error
LOG_LEVEL=info

# Optional shared secret for future auth (leave blank to disable)
API_SECRET=
