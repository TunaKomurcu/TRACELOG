# Tracelog M6 - Slack Bot
# Copy to .env and fill in your tokens

# Slack app credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token

# Alert channel (default: #tracelog-alerts)
SLACK_ALERT_CHANNEL= tracelog-alerts

# Backend service URLs
M2_URL=http://localhost:8765
M3_URL=http://localhost:8002
M4_URL=http://localhost:8766
M5_URL=http://localhost:8767

# HTTP timeout for service calls (seconds)
HTTP_TIMEOUT=5

# Slack Bot listening port
SLACK_PORT=3000
